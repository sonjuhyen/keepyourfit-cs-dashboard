# cs-dashboard — 로컬 개발 + Vercel 환경변수
# Vercel 프로덕션에는 Vercel 대시보드 → Settings → Environment Variables 에서 설정한다.

# Cloudflare Worker (channeltalk-cs-automation) URL
# 예: https://channeltalk-cs-automation.<your-subdomain>.workers.dev
WORKER_URL=

# Worker admin endpoint 보호용 토큰 (Worker secret ADMIN_TOKEN과 동일)
WORKER_TOKEN=

# 로컬 서버 포트 (선택)
PORT=3000
